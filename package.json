{
  "name": "@tree-sitter-grammars/tree-sitter-svelte",
  "version": "1.0.2",
  "description": "Svelte grammar for tree-sitter",
  "repository": "https://github.com/tree-sitter-grammars/tree-sitter-svelte",
  "funding": "https://github.com/sponsors/amaanq",
  "license": "MIT",
  "author": {
    "name": "Amaan Qureshi",
    "email": "amaanq12@gmail.com"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "svelte"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.2.1",
    "node-gyp-build": "^4.8.2",
    "tree-sitter-html": "^0.23.2"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "eslint-config-treesitter": "^1.0.2",
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "^0.25.6"
  },
  "peerDependencies": {
    "tree-sitter": "^0.22.4"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "overrides": {
    "tree-sitter": "^0.22.4"
  },
  "scripts": {
    "install": "node-gyp-build",
    "lint": "eslint grammar.js",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  }
}
